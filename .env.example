# Facebook session cookies — copy from DevTools > Application > Cookies > facebook.com
# Re-copy whenever requests start returning login redirects (~30 day expiry)
FB_DATR=
FB_SB=
FB_C_USER=        # your numeric user ID (same as c_user cookie)
FB_FR=
FB_XS=

# Search parameters
SEARCH_LAT=29.4167          # decimal latitude of your search center (unused by Playwright — kept for future use)
SEARCH_LNG=-98.5
SEARCH_RADIUS_M=65000

# Scrape pacing — stay at human-like rates
DELAY_MIN_S=4
DELAY_MAX_S=12
